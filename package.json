{
  "name": "unity-mcp-bridge",
  "version": "0.1.0",
  "description": "Bridge Claude Code (in WSL) to the Unity Editor on Windows: checks Unity, stages an MCP server, registers it with Claude Code, and wires up the live Editor bridge.",
  "bin": {
    "unity-mcp-bridge": "bin/cli.js",
    "unity-mcp": "bin/cli.js"
  },
  "scripts": {
    "check": "node bin/cli.js check",
    "setup": "node bin/cli.js setup"
  },
  "files": [
    "assets/",
    "bin/",
    "server/",
    "unity/",
    "setup/UnityMCPSetup.cs",
    "setup/UnityMCPSetup.exe",
    "setup/build_exe.sh",
    "scripts/",
    ".claude/skills/",
    "Integration-plan.md",
    "prompt.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "unity",
    "mcp",
    "claude",
    "claude-code",
    "wsl",
    "game-development",
    "unity-editor"
  ],
  "license": "MIT"
}
